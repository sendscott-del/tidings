{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "glad-tidings.vercel.app" }],
      "destination": "https://tidings.gatheredin.app/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "glad-tidings.vercel.app" }],
      "destination": "https://tidings.gatheredin.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!apple-touch-icon\\.png|favicon\\.png|favicon\\.svg|manifest\\.json|sw\\.js|icon-.*\\.png|assets/.*).*)", "destination": "/index.html" }
  ]
}
